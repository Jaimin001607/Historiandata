# Ignore everything at the home directory root
*

# Allow git config and this file
!.gitignore

# Allow the project folder itself
!/Historian sensor alert system/

# Allow project source files inside the folder
!"/Historian sensor alert system/*.py"
!"/Historian sensor alert system/*.txt"
!"/Historian sensor alert system/.gitignore"

# Keep data/output folders excluded even inside the project folder
"/Historian sensor alert system/trained_models/"
"/Historian sensor alert system/sensor_training_data/"
"/Historian sensor alert system/historian_data/"
"/Historian sensor alert system/__pycache__/"
